{
  "name": "formant",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "vitest",
    "test:e2e": "pnpm --filter e2e test",
    "formant": "tsx packages/html-builder/src/cli.ts",
    "build:runtime": "tsx packages/html-builder/src/cli.ts build-runtime",
    "build:runtime:embed": "tsx packages/html-builder/src/cli.ts build-runtime --embed packages/service/src/generated/runtime-embed.ts",
    "deploy": "tsx packages/html-builder/src/cli.ts deploy",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write ."
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "prettier": "^3",
    "tsx": "^4.21.0",
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
